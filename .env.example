# MentraOS Configuration
PACKAGE_NAME=com.suhail.assistant
MENTRAOS_API_KEY=
PORT=3000

# AI Service API Keys
OPENROUTER_API_KEY=
# VISION_MODEL=google/gemini-2.5-flash-lite
# CLASSIFICATION_MODEL=google/gemini-2.5-flash-lite
AWS_REGION=us-east-1
AWS_REKOGNITION_COLLECTION_ID=suhail-faces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# App Configuration
DEFAULT_LANGUAGE=ar
CONFIDENCE_THRESHOLD=0.5
MIN_CONFIDENCE=0.55

# Publicly reachable base URL of this server (no trailing slash).
# Dev: your ngrok URL. Prod: your Railway URL.
# When set, short generated chimes replace the "Listening" / "Got it" / "Cancelled"
# TTS cues (saves ~4-5s per command). Leave empty to keep the spoken fallback.
# PUBLIC_BASE_URL=https://unplummeted-teddy-extractable.ngrok-free.dev
